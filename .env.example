EXPO_PUBLIC_ERP_API_BASE_URL=https://dashboard.sidomulyoproject.com/api
EXPO_PUBLIC_ALLOW_LOCAL_ERP_API=
# Contoh deploy:
# EXPO_PUBLIC_ERP_API_BASE_URL=https://dashboard.sidomulyoproject.com/api
# Contoh LAN jika backend jalan di komputer lain:
# EXPO_PUBLIC_ERP_API_BASE_URL=http://192.168.1.10:8000/api
# Jika benar-benar ingin memaksa pakai backend lokal, isi 1:
# EXPO_PUBLIC_ALLOW_LOCAL_ERP_API=1
EXPO_PUBLIC_ERP_EMAIL=
EXPO_PUBLIC_ERP_PASSWORD=
# Optional: if you want to skip login request and use fixed token
EXPO_PUBLIC_ERP_TOKEN=
# Optional: kalau kosong, app akan otomatis pakai versi dari package.json
EXPO_PUBLIC_APP_VERSION=
EXPO_PUBLIC_BANK_ACCOUNT_CASH_ID=
EXPO_PUBLIC_BANK_ACCOUNT_TRANSFER_ID=
EXPO_PUBLIC_BANK_ACCOUNT_QRIS_ID=
EXPO_PUBLIC_BANK_ACCOUNT_CARD_ID=
EXPO_PUBLIC_BANK_ACCOUNT_DEFAULT_ID=


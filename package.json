{
  "name": "pos-kasir-expo",
  "version": "1.6.3",
  "description": "Aplikasi desktop POS Kasir untuk operasional penjualan dan closing harian.",
  "author": "Sidomulyo",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test:product-picker": "node --test src/utils/__tests__/productPickerTree.test.cjs",
    "test:receipt-summary": "node --test src/utils/__tests__/receiptSummary.test.cjs",
    "test:receipt-render": "npx tsc --noEmit src/printing/renderReceiptText.ts src/printing/receiptHelpers.ts src/printing/profiles.ts src/printing/types.ts src/printing/__tests__/renderReceiptText.test.ts",
    "build:web": "set NODE_OPTIONS=--max-old-space-size=4096 && npx expo export --platform web --output-dir dist-web --max-workers 1",
    "desktop": "npm run build:web && electron electron/main.js",
    "build:win": "npm run build:web && node scripts/build-velopack.js",
    "build:pages": "npm run build:win && node scripts/prepare-pages-site.js",
    "build:win:dir": "npm run build:web && electron-builder --win dir",
    "build:win:legacy": "npm run build:web && electron-builder --win nsis"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-font": "^55.0.6",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "^15.12.1",
    "react-native-web": "^0.21.0",
    "velopack": "^0.0.1589-ga2c5a97"
  },
  "devDependencies": {
    "@electron/windows-sign": "^1.2.2",
    "@types/react": "~19.1.10",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "~5.9.2"
  },
  "build": {
    "appId": "com.sidomulyo.poskasir",
    "productName": "POS Kasir",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "copyright": "Copyright © 2026 Sidomulyo",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "node_modules/velopack/**/*",
      "node_modules/@neon-rs/load/**/*"
    ],
    "files": [
      "dist-web/**/*",
      "electron/**/*",
      "node_modules/velopack/**/*",
      "node_modules/@neon-rs/load/**/*",
      "assets/icon.png",
      "assets/iconsm.ico",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "legalTrademarks": "Sidomulyo",
      "target": [
        "dir"
      ],
      "icon": "assets/iconsm.ico",
      "signAndEditExecutable": false
    }
  },
  "private": true
}
